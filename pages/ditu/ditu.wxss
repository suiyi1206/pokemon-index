/* pages/map/map.wxss */
.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.4);
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
}

/* 地图选择器 */
.map-selector {
  white-space: nowrap;
  width: 100%;
  margin-bottom: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 20rpx;
}

.map-list {
  display: inline-flex;
  gap: 20rpx;
}

.map-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
  min-width: 120rpx;
  transition: all 0.3s ease;
}

.map-item.active {
  background: #ff6b6b;
  transform: scale(1.05);
}

.map-item.active .map-name {
  color: white;
}

.map-thumbnail {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  object-fit: cover;
}

.map-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.map-item.active .map-name {
  color: white;
}

/* 主地图容器 */
.main-map-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.main-map {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.map-info {
  padding: 0 10rpx;
}

.map-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
  text-align: center;
}

.map-description {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: block;
}

/* 特征标签 */
.feature-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.feature-tag {
  background: linear-gradient(135deg, #ff6b6b 0%, #a78bfa 100%);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.tag-text {
  font-size: 22rpx;
  color: white;
  font-weight: 500;
}

/* 地图导航 */
.map-navigation {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 20rpx;
}

.nav-button {
  display: flex;
  align-items: center;
  padding: 15rpx 25rpx;
  background: #ff6b6b;
  border-radius: 12rpx;
  color: white;
  font-weight: 500;
}

.nav-icon {
  font-size: 28rpx;
  margin: 0 8rpx;
}

.nav-text {
  font-size: 26rpx;
}

.map-indicator {
  display: flex;
  align-items: baseline;
}

.current-index {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.total-maps {
  font-size: 24rpx;
  color: #666;
}