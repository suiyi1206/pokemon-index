.gallery-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin: 30rpx 0;
  color: #333;
}

.section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

/* 特色图片样式 */
.featured-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

/* 图片网格样式 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.grid-item {
  width: 48%;
  margin-bottom: 20rpx;
}

.grid-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
}

.image-title {
  display: block;
  font-size: 24rpx;
  color: #888;
  text-align: center;
  margin-top: 10rpx;
}

/* 横向滚动样式 */
.horizontal-scroll {
  white-space: nowrap;
  width: 100%;
}

.scroll-container {
  display: inline-block;
}

.scroll-image {
  width: 250rpx;
  height: 200rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  display: inline-block;
}