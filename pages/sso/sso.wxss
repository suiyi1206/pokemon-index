/* pages/dw/dw.wxss */
/* pages/pokemon-card/pokemon-card.wxss */
.card-list {
  padding: 16rpx;
}
.pokemon-card {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  padding: 16rpx;
  margin-bottom: 20rpx;
}
.pokemon-icon {
  width: 120rpx;
  height: 120rpx;
  margin-right: 16rpx;
}
.info-wrapper {
  flex: 1;
}
.header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.name {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 8rpx;
}
.gender-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
}
.type-list {
  display: flex;
}
.type {
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #fff;
  margin-right: 6rpx;
}
.feature-stats {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}
.feature, .stats, .item {
  margin-bottom: 6rpx;
}
.label {
  color: #666;
}
.moves {
  display: flex;
  flex-wrap: wrap;
}
.move {
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #fff;
  margin: 4rpx;
}