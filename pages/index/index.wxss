/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff9ecb 0%, #a78bfa 100%);
  padding: 0;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx 10rpx;
  color: #fff;
}

.time {
  font-size: 28rpx;
  font-weight: 500;
}

.battery-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.battery {
  font-size: 26rpx;
}

.battery-icon {
  font-size: 24rpx;
}
/* 右上角地区切换 */
.region-switcher {
  position: absolute;
  top: 120rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
  z-index: 100;
}

.region-switcher-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.region-switcher-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #ff6b6b;
}

/* 地区下拉菜单 */
.region-dropdown {
  position: absolute;
  top: 160rpx;
  right: 30rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 99;
  min-width: 180rpx;
}

.region-dropdown-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.region-dropdown-item:last-child {
  border-bottom: none;
}

.region-dropdown-item.active {
  background: #fff5f5;
}

.region-dropdown-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  width: 30rpx;
  text-align: center;
}

.region-dropdown-name {
  font-size: 24rpx;
  color: #333;
}

/* 地区标题 */
.region-header {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.region-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

/* 功能按钮通用样式 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* 调整为3列布局 */
  gap: 20rpx;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 25rpx 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.function-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 15rpx;
}

/* 道馆图标特殊样式 */
.daoguan-icon {
  width: 50rpx;  /* 图片显示尺寸 */
  height: 50rpx;
}

.function-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

/* 道馆按钮高亮样式 */
.function-item:nth-child(3) {
  background: rgba(255, 245, 245, 0.95);
  border: 1rpx solid #ffcccc;
}

.function-item:nth-child(3) .function-label {
  color: #ff6b6b;
  font-weight: bold;
}
/* 地区介绍 */
.region-intro {
  background: rgba(255, 255, 255, 0.9);
  margin: 0 30rpx;
  padding: 25rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.intro-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 15rpx;
  text-align: center;
}

.intro-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  text-align: center;
}

/* 特色宝可梦 */
.featured-pokemon {
  background: rgba(255, 255, 255, 0.9);
  margin: 80rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 20rpx;
  text-align: center;
}

.pokemon-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.pokemon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 150rpx;      /* 缩小容器宽度 */
}

.pokemon-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.pokemon-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}
.pokemon-image {
  width: 600rpx;
  height: 200rpx;
  transform: scale(0.1);
  transform-origin: center;
  margin-bottom: 10rpx;
}