  width: 750rpx;
  height: 80vh;
  margin-bottom: 30rpx;
  background: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 极速.1);
}
.image-sx {
            width: 600px;
            height: 400px;
            transform: scale(1.03);
            transform-origin: center;
            margin-bottom: 10px;
            border: 3px solid #e0e0e0;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
